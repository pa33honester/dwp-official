# DWP — Hostinger shared (Apache) static hosting
# Generated for the static-exported Next.js bundle.

RewriteEngine On

# Force HTTPS (Hostinger auto-issues Let's Encrypt for the domain)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Drop www (optional — comment out if you prefer www as canonical)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# Custom 404 (Next exports 404.html automatically)
ErrorDocument 404 /404.html

# Cache hashed Next.js bundles aggressively
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|ttf|otf|svg|png|jpg|jpeg|webp|gif|ico|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Don't cache the HTML shell — content can change between deploys
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Security headers
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

# Gzip / brotli compression for text assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
